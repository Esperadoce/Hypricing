<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Hypricing.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Hypricing.Desktop.Views.BackupView"
             x:DataType="vm:BackupViewModel">

    <DockPanel>

        <TextBlock DockPanel.Dock="Top"
                   Classes="page-title"
                   Text="Backups" />

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom"
                Classes="card-elevated"
                CornerRadius="12,12,0,0"
                Padding="20,14"
                Margin="0,16,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Classes="status"
                           Text="{Binding StatusMessage}" />
                <Button Grid.Column="1"
                        Classes="accent"
                        Content="Create Backup"
                        Command="{Binding CreateBackupCommand}" />
            </Grid>
        </Border>

        <!-- Backup list -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Backups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:BackupItemViewModel">
                        <Border Classes="card-item"
                                Padding="16,12"
                                Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*,Auto,Auto">
                                <StackPanel Grid.Column="0" Spacing="6">
                                    <TextBlock Text="{Binding Info.FileName}"
                                               FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                               FontSize="13"
                                               Foreground="#cdd6f4" />
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <TextBlock Classes="muted"
                                                   Text="{Binding Info.CreatedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" />
                                        <TextBlock Classes="muted"
                                                   Text="{Binding Info.SizeDisplay}" />
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Classes="ghost"
                                        Content="Restore"
                                        Command="{Binding RestoreCommand}"
                                        Margin="0,0,8,0" />
                                <Button Grid.Column="2"
                                        Classes="danger"
                                        Content="Delete"
                                        Command="{Binding DeleteCommand}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>

</UserControl>
