<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Hypricing.Desktop.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Hypricing.Desktop.Views.StartupView"
             x:DataType="vm:StartupViewModel">

    <DockPanel>

        <TextBlock DockPanel.Dock="Top"
                   Classes="page-title"
                   Text="Startup" />

        <!-- Bottom bar -->
        <Border DockPanel.Dock="Bottom"
                Classes="card-elevated"
                CornerRadius="12,12,0,0"
                Padding="20,14"
                Margin="0,16,0,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Classes="status"
                           Text="{Binding StatusMessage}" />
                <Button Grid.Column="1"
                        Classes="accent"
                        Content="Save"
                        Command="{Binding SaveCommand}" />
            </Grid>
        </Border>

        <ScrollViewer>
            <StackPanel Spacing="16">

                <!-- Add new entry -->
                <Border Classes="card-elevated">
                    <Grid ColumnDefinitions="140,*,Auto">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{x:Static vm:ExecItemViewModel.AllVariants}"
                                  SelectedItem="{Binding NewVariant}"
                                  Margin="0,0,8,0" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding NewCommand, Mode=TwoWay}"
                                 Watermark="Command to run..."
                                 Margin="0,0,8,0" />
                        <Button Grid.Column="2"
                                Classes="accent"
                                Content="Add"
                                Command="{Binding AddCommand}" />
                    </Grid>
                </Border>

                <!-- Exec entries list -->
                <Border Classes="card">
                    <ItemsControl ItemsSource="{Binding ExecEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ExecItemViewModel">
                                <Border Classes="card-item">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0"
                                                Classes="badge"
                                                VerticalAlignment="Center"
                                                Margin="0,0,12,0">
                                            <TextBlock Text="{Binding VariantDisplay}"
                                                       FontFamily="JetBrains Mono, Cascadia Code, monospace"
                                                       FontSize="12"
                                                       Foreground="#a6e3a1" />
                                        </Border>
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Command, Mode=TwoWay}"
                                                 Margin="0,0,10,0" />
                                        <Button Grid.Column="2"
                                                Classes="danger"
                                                Content="Remove"
                                                Command="{Binding RemoveCommand}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>

</UserControl>
